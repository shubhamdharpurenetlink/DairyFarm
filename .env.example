# Laxmi Dairy Farm — environment variables
# Copy to .env.local for local dev. Set the same vars in Vercel for prod.

# --- Database (Neon Postgres) ----------------------------------------------
# Pooled connection (used by serverless functions) — Neon "Pooled connection"
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/laxmi_dairy?sslmode=require"
# Direct connection (used by Prisma migrate) — Neon "Direct connection"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/laxmi_dairy?sslmode=require"
# Force Neon serverless adapter even in dev (optional)
# PRISMA_USE_NEON_ADAPTER=1

# --- Auth.js (NextAuth v5) -------------------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="please-generate-a-secure-random-string"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# --- Admin seed user --------------------------------------------------------
ADMIN_EMAIL="admin@laxmidairy.in"
# Plain password used ONLY by `npm run db:seed` if ADMIN_PASSWORD_HASH is unset
ADMIN_PASSWORD="admin123"
# Optional: pre-hashed bcrypt hash (preferred for prod). Run:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=""

# --- Razorpay (test keys by default; swap for live in prod) ----------------
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# --- App URL ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
