// Laxmi Dairy Farm — Postgres schema (Neon + Prisma)
// Bilingual { en, hi } fields use Json columns to mirror existing TS types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth ----------

enum UserRole {
  owner
  editor
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(owner)
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Products ----------

model Category {
  slug        String   @id
  name        Json
  icon        String
  color       String
  description Json?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                Json
  shortDesc           Json
  description         Json
  category            String
  primaryImage        String
  images              String[]
  variants            Json
  tags                String[]
  isFeatured          Boolean  @default(false)
  isAvailable         Boolean  @default(true)
  rating              Float?
  ratingCount         Int?
  badges              Json?
  shelfLifeDays       Int?
  storageInstructions Json?
  ingredients         Json?
  nutrition           Json?
  publishedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([isAvailable, isFeatured])
}

// ---------- Orders ----------

enum OrderStatus {
  pending
  confirmed
  preparing
  out_for_delivery
  delivered
  cancelled
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customer        Json
  items           Json
  subtotalInr     Int
  deliveryFeeInr  Int
  totalInr        Int
  status          OrderStatus @default(pending)
  paymentMode     String
  paymentRef      String?
  razorpayOrderId String?     @unique
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ---------- Cows ----------

model Cow {
  slug                  String   @id
  nameEn                String
  nameHi                String
  category              String
  origin                String
  color                 String
  milkYieldLitresPerDay Json
  fatPercent            Float
  image                 String
  gallery               String[]
  shortDesc             Json
  description           Json
  characteristics       Json
  history               Json
  temperament           Json
  suitability           Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ---------- Knowledge / Diseases ----------

model Disease {
  slug        String   @id
  title       Json
  category    String
  image       String
  summary     Json
  symptoms    Json
  causes      Json
  prevention  Json
  treatment   Json
  readTimeMin Int      @default(5)
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// ---------- Training ----------

enum TrainingLevel {
  beginner
  intermediate
  advanced
}

model Training {
  slug         String        @id
  title        Json
  shortDesc    Json
  longDesc     Json
  image        String
  durationDays Int
  priceInr     Int
  level        TrainingLevel @default(beginner)
  seatsTotal   Int
  seatsLeft    Int
  syllabus     Json
  instructor   Json
  schedule     Json
  includes     Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  enrollments Enrollment[]
}

enum EnrollmentStatus {
  pending
  confirmed
  completed
  cancelled
}

model Enrollment {
  id              String           @id @default(cuid())
  trainingId      String
  trainingTitleEn String
  fullName        String
  phone           String
  email           String
  age             Int
  state           String
  district        String
  education       String
  batchDate       String
  source          String?
  message         String?
  status          EnrollmentStatus @default(pending)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  training Training? @relation(fields: [trainingId], references: [slug], onDelete: SetNull)

  @@index([status])
  @@index([trainingId])
}

// ---------- Gallery ----------

enum GalleryType {
  photo
  video
}

model GalleryItem {
  id          String      @id @default(cuid())
  type        GalleryType
  url         String
  thumbnail   String
  title       Json
  aspectRatio Float?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
}

// ---------- About content ----------

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      Json
  avatar    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimelineEvent {
  id          String   @id @default(cuid())
  year        String
  title       Json
  description Json
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Award {
  id        String   @id @default(cuid())
  year      String
  title     Json
  issuer    String
  icon      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Facility {
  id          String   @id @default(cuid())
  name        Json
  description Json
  image       String
  icon        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Engagement ----------

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  city      String
  avatar    String
  rating    Int      @default(5)
  quote     Json
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EnquiryStatus {
  new
  open
  resolved
  spam
}

model Enquiry {
  id        String        @id @default(cuid())
  name      String
  phone     String
  email     String
  subject   String
  message   String
  status    EnquiryStatus @default(new)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ---------- Site settings (singleton row, id = "default") ----------

model Settings {
  id                  String   @id @default("default")
  farmName            Json
  tagline             Json
  foundedYear         Int
  address             Json
  phone               String
  whatsapp            String
  email               String
  hours               Json
  socials             Json
  stats               Json
  delivery            Json
  updatedAt           DateTime @updatedAt
}
